{
  "manifest_version": 3,
  "name": "Auto Bing Search Extension",
  "version": "1.0",
  "description": "자동으로 Bing에서 키워드 검색 및 연관 검색어 추출을 수행합니다",
  "permissions": ["sidePanel", "activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://www.bing.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bing.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Auto Bing Search Open",
    "default_icon": {
      "128": "images/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "icons": {
    "128": "images/icon-128.png"
  }
}
